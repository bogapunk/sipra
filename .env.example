# Copie este archivo a .env y ajuste los valores.
# SIPRA usa exclusivamente Microsoft SQL Server 2022.

# --- ENTORNO LOCAL ---
DEBUG=1
SECRET_KEY=sipra-local-dev-key-cambiar-en-produccion
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOW_ALL_ORIGINS=1
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

# --- BASE DE DATOS SQL SERVER ---
# Local: Sipra-Test | Producción (docker-compose.produccion.yml): Sipra
DB_TYPE=mssql
DB_HOST=10.1.9.113
DB_PORT=1433
DB_NAME=Sipra-Test
DB_USER=SA
DB_PASSWORD=Davinci2024#
# Controlador ODBC (Windows local): instale desde
# https://learn.microsoft.com/sql/connect/odbc/download-odbc-driver-for-sql-server
# Use "ODBC Driver 17 for SQL Server" o "ODBC Driver 18 for SQL Server"
DB_ODBC_DRIVER=ODBC Driver 17 for SQL Server

# --- USUARIOS BOOTSTRAP LOCAL ---
BOOTSTRAP_ADMIN_EMAIL=admin@sipra.local
BOOTSTRAP_ADMIN_PASSWORD=AdminSipra2026!
BOOTSTRAP_ADMIN_NOMBRE=Administrador
BOOTSTRAP_ADMIN_APELLIDO=SIPRA
BOOTSTRAP_CARGA_EMAIL=gestion.proyectos@sipra.local
BOOTSTRAP_CARGA_PASSWORD=GestionSipra2026!
BOOTSTRAP_CARGA_NOMBRE=Gestion
BOOTSTRAP_CARGA_APELLIDO=Proyectos
BOOTSTRAP_VISUALIZADOR_EMAIL=visualizacion@sipra.local
BOOTSTRAP_VISUALIZADOR_PASSWORD=VisualSipra2026!
BOOTSTRAP_VISUALIZADOR_NOMBRE=Consulta
BOOTSTRAP_VISUALIZADOR_APELLIDO=General

# --- JWT / SESION ---
JWT_EXPIRES_HOURS=8
JWT_ISSUER=sipra
JWT_AUDIENCE=sipra-web
ACTIVE_SESSION_MINUTES=5

# --- ADJUNTOS ---
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=pdf,doc,docx,xls,xlsx,ppt,pptx,csv,txt,png,jpg,jpeg,webp

# --- LOGGING ---
LOG_LEVEL=INFO
# En Windows, si deja sipra.log abierto en el IDE y hay errores al rotar, use LOG_ENABLE_FILE=0
# y revise solo la consola donde ejecuta runserver (no se escribe backend/logs/sipra.log).
LOG_ENABLE_FILE=1
LOG_DIR=
LOG_FILE_NAME=sipra.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# --- BACKUPS ---
# Estructura: backups/sql/YYYY-MM-DD/sipra_*.sql (local y producción)
# BACKUP_DIR=./backend/backups
# BACKUP_SQL_DIR=./backend/backups/sql

# --- PRODUCCION (docker-compose.produccion.yml) ---
# Ajustes de dominio/CORS en ese archivo o en el servidor; este .env es sobre todo para LOCAL.
