# Copie este archivo a .env y ajuste los valores
# Para usar PostgreSQL en desarrollo local, defina DATABASE_URL

# Base de datos PostgreSQL (si está definido, reemplaza SQLite)
# Formato: postgres://usuario:password@host:puerto/nombre_bd
DATABASE_URL=postgres://sipra:tu_password@localhost:5432/sipra

# Django - DESARROLLO
SECRET_KEY=cambie-esta-clave-por-una-segura-en-produccion
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

